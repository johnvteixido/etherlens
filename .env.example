# Environment Variables for EtherLens Server
# Copy this file to .env and fill in your values. Never commit .env to version control.

# ─── API Security ───────────────────────────────────────────────
# API key required by clients in the `x-api-key` header.
# CHANGE THIS to a long random secret before deploying!
API_KEY=etherlens_admin

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# ─── Server ─────────────────────────────────────────────────────
# Port for the REST API. Defaults to 3001.
PORT=3001

# ─── Scanner ────────────────────────────────────────────────────
# Number of concurrent TCP scan sockets spun up by the daemon.
CONCURRENCY_LIMIT=200

# Comma-separated list of TCP ports to probe.
TARGET_PORTS=22,80,443,21,3389,8080

# Timeout in milliseconds per connection attempt.
SCAN_TIMEOUT_MS=2000
